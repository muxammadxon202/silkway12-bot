# Скопируй в .env и заполни РЕАЛЬНЫМИ значениями на VPS.
# .env в git НЕ коммитится (см. .gitignore). Токен сюда НЕ вставляй.

# Токен бота от @BotFather
BOT_TOKEN=123456:PUT_YOUR_TOKEN_HERE

# Пароль БД — сгенерируй свой: openssl rand -base64 24
# (используется и здесь, и в docker-compose.yml для контейнера db)
POSTGRES_PASSWORD=PUT_A_STRONG_RANDOM_PASSWORD_HERE

# Строка подключения к PostgreSQL (asyncpg) — пароль должен совпадать с POSTGRES_PASSWORD выше
DATABASE_URL=postgresql+asyncpg://silkway:PUT_A_STRONG_RANDOM_PASSWORD_HERE@db:5432/silkway

# Домены сайта для CORS (только они смогут слать заявки). Через запятую.
# Сейчас сайт живёт на GitHub Pages; добавь свой домен, когда подключишь.
# Локальная отладка: http://localhost:8422
ALLOWED_ORIGINS=https://muxammadxon202.github.io,https://silkway12.uz,https://www.silkway12.uz

# ОБЯЗАТЕЛЬНО: твой Telegram ID. Узнать за 5 секунд — напиши @userinfobot.
# Бот не запустится без этого значения — так и задумано: раньше при пустом
# ADMIN_ID админом становился первый, кто напишет /start, а это чужой человек
# мог перехватить все заявки с сайта раньше тебя.
ADMIN_ID=

# Поддомен для API — Caddy выпустит на него HTTPS-сертификат автоматически.
# A-запись этого поддомена должна указывать на IP сервера.
API_DOMAIN=api.silkway12.uz
