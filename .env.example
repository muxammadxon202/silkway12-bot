# Скопируй в .env и заполни РЕАЛЬНЫМИ значениями на VPS.
# .env в git НЕ коммитится (см. .gitignore). Токен сюда НЕ вставляй.

# Токен бота от @BotFather
BOT_TOKEN=123456:PUT_YOUR_TOKEN_HERE

# Строка подключения к PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://silkway:silkway@db:5432/silkway

# Домены сайта для CORS (только они смогут слать заявки). Через запятую.
# Сейчас сайт живёт на GitHub Pages; добавь свой домен, когда подключишь.
# Локальная отладка: http://localhost:8422
ALLOWED_ORIGINS=https://muxammadxon202.github.io,https://silkway12.uz,https://www.silkway12.uz

# Необязательно: если знаешь свой Telegram ID заранее — впиши сюда.
# Если пусто — первый, кто напишет боту /start, станет админом (ID выведется в консоль).
ADMIN_ID=
